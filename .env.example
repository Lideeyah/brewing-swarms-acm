# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional: Solana on-chain escrow ──────────────────────────────────────────
# Set SOLANA_MODE=1 to route escrow through the deployed Brewing Anchor program
# instead of the in-process simulation.
SOLANA_MODE=0

# Solana RPC endpoint (only needed when SOLANA_MODE=1)
RPC_URL=https://api.devnet.solana.com

# Orchestrator keypair — JSON byte-array from `solana-keygen new`
# Must hold ≥ 0.50 devnet USDC to cover sub-task payments
# Get devnet USDC at https://faucet.circle.com (select Solana Devnet)
POSTER_SECRET_KEY=

# ── Optional: governance overrides ───────────────────────────────────────────
# Override the default 7/10 verification threshold
# GOVERNANCE_THRESHOLD=7

# Override the default 300s SLA per sub-task
# GOVERNANCE_SLA_SECONDS=300
